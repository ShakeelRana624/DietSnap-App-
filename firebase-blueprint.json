{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User settings and biological data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "weight": { "type": "number" },
        "height": { "type": "number" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "activityLevel": { "type": "string", "enum": ["sedentary", "light", "moderate", "active", "very_active"] },
        "goalType": { "type": "string", "enum": ["lose", "maintain", "gain"] },
        "goal": { "type": "number" },
        "streak": { "type": "number" },
        "lastGoalUpdate": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "displayName", "email", "weight", "height", "goal", "createdAt"]
    },
    "Meal": {
      "title": "Meal Log",
      "description": "Log of a meal consumed by a user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "foodName": { "type": "string" },
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "carbs": { "type": "number" },
        "fat": { "type": "number" },
        "portion": { "type": "string", "enum": ["Small", "Medium", "Large"] },
        "grade": { "type": "string", "enum": ["A", "B", "C", "D", "F"] },
        "timestamp": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["uid", "foodName", "calories", "protein", "carbs", "fat", "portion", "grade", "timestamp"]
    },
    "Water": {
      "title": "Water Log",
      "description": "Log of water intake by a user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "amount": { "type": "number" },
        "timestamp": { "type": "string" }
      },
      "required": ["uid", "amount", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Top-level user profiles"
    },
    "/users/{userId}/meals/{mealId}": {
      "schema": "Meal",
      "description": "Subcollection of meal logs for a specific user"
    },
    "/users/{userId}/water/{waterId}": {
      "schema": "Water",
      "description": "Subcollection of water intake logs"
    }
  }
}
