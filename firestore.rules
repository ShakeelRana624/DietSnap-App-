rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'weight', 'height', 'goal', 'createdAt'])
        && data.keys().size() <= 25
        && data.uid == request.auth.uid
        && data.email is string
        && data.weight is number
        && data.height is number
        && data.goal is number
        && data.createdAt is string;
    }

    function isValidMeal(data) {
      return data.keys().hasAll(['uid', 'foodName', 'calories', 'protein', 'carbs', 'fat', 'portion', 'grade', 'timestamp'])
        && data.keys().size() <= 12
        && data.uid == request.auth.uid
        && data.foodName is string && data.foodName.size() <= 200
        && data.calories is number
        && data.protein is number
        && data.carbs is number
        && data.fat is number
        && data.portion in ['Small', 'Medium', 'Large', 'Custom']
        && data.grade in ['A', 'B', 'C', 'D', 'F', 'Manual']
        && data.timestamp is string;
    }

    function isValidWeight(data) {
      return data.keys().hasAll(['uid', 'weight', 'timestamp'])
        && data.keys().size() <= 5
        && data.uid == request.auth.uid
        && data.weight is number && data.weight > 0
        && data.timestamp is string;
    }

    function isValidWater(data) {
      return data.keys().hasAll(['uid', 'amount', 'timestamp'])
        && data.keys().size() <= 5
        && data.uid == request.auth.uid
        && data.amount is number && data.amount > 0
        && data.timestamp is string;
    }

    // 4. Match Blocks
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && isValidId(userId);
      allow update: if isOwner(userId) && isValidUser(incoming()) && isValidId(userId)
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt;
      
      match /meals/{mealId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMeal(incoming()) && isValidId(mealId);
        allow update: if isOwner(userId) && isValidMeal(incoming()) && isValidId(mealId)
          && incoming().uid == existing().uid
          && incoming().timestamp == existing().timestamp;
        allow delete: if isOwner(userId) && isValidId(mealId);
      }

      match /weights/{weightId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidWeight(incoming()) && isValidId(weightId);
        allow delete: if isOwner(userId) && isValidId(weightId);
      }

      match /water/{waterId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidWater(incoming()) && isValidId(waterId);
        allow delete: if isOwner(userId) && isValidId(waterId);
      }
    }
  }
}
